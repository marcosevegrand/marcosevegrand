---
import { marked } from 'marked';
import SectionReveal from '../components/SectionReveal';
import content from '../content/portfolio.json';
import '../styles/global.css';

const mdInline = (value: string) => marked.parseInline(value);
const {
  meta,
  nav,
  hero,
  sections,
  about,
  experience,
  education,
  certifications,
  projects
} = content;
---

<html lang={meta.lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{meta.title}</title>
    <meta name="description" content={meta.description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Space+Grotesk:wght@600;700&family=Space+Mono&display=swap"
      rel="stylesheet"
    />
  </head>
  <body id="top">
    <div class="ambient" aria-hidden="true">
      <span></span>
      <span></span>
    </div>
    <div class="cursor-glow" aria-hidden="true"></div>
    <div class="scroll-progress" aria-hidden="true"><span id="scrollProgressBar"></span></div>
    <div class="lightbox" id="imageLightbox" aria-hidden="true">
      <button type="button" class="lightbox-nav prev" id="lightboxPrev" aria-label="Previous image">‹</button>
      <button type="button" class="lightbox-nav next" id="lightboxNext" aria-label="Next image">›</button>
      <button type="button" class="lightbox-close" id="lightboxClose" aria-label="Close image preview">✕</button>
      <img id="lightboxImage" src="" alt="" class="lightbox-image" />
    </div>

    <aside class="rope-nav" aria-label="Section navigation">
      <nav>
        <ul>
          {nav.map((item) => (
            <li>
              <a href={item.href} class="rope-link">{item.label}</a>
            </li>
          ))}
        </ul>
      </nav>
    </aside>

    <main class="page-shell">
      <section id="hero" class="section hero kinetic-hero">
        <p class="mono role">{hero.role}</p>
        <h1>
          <img src="/logo.png" alt={hero.name} class="hero-logo" />
        </h1>
        <p class="hero-meta muted" data-timezone={hero.timezone || 'Europe/Lisbon'}>
          {hero.location || 'Braga, Portugal'} · Local time: <span id="heroLocalTime">--:--</span>
        </p>

        <div class="hero-cta">
          {hero.links.map((item) => (
            <a href={item.href} class="action-link">
              {item.label === 'Email' && (
                <svg aria-hidden="true" viewBox="0 0 24 24" fill="none">
                  <path d="M4 7h16v10H4z" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"></path>
                  <path d="m5 8 7 6 7-6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"></path>
                </svg>
              )}
              {item.label === 'GitHub' && (
                <svg aria-hidden="true" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M12 2a10 10 0 0 0-3.16 19.49c.5.09.68-.22.68-.48v-1.7c-2.78.6-3.37-1.18-3.37-1.18-.45-1.16-1.1-1.47-1.1-1.47-.9-.62.07-.61.07-.61 1 .07 1.52 1.03 1.52 1.03.88 1.52 2.3 1.08 2.86.83.09-.64.35-1.08.63-1.33-2.22-.25-4.56-1.12-4.56-4.97 0-1.1.4-1.99 1.03-2.7-.1-.25-.45-1.27.1-2.66 0 0 .85-.27 2.78 1.03a9.6 9.6 0 0 1 5.06 0c1.93-1.3 2.78-1.03 2.78-1.03.55 1.39.2 2.41.1 2.66.64.7 1.03 1.6 1.03 2.7 0 3.86-2.35 4.72-4.58 4.97.36.31.67.92.67 1.86v2.75c0 .26.18.58.69.48A10 10 0 0 0 12 2Z"></path>
                </svg>
              )}
              {item.label === 'LinkedIn' && (
                <svg aria-hidden="true" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M6.94 8.5A1.56 1.56 0 1 1 6.9 5.4a1.56 1.56 0 0 1 .04 3.1ZM5.62 9.7h2.56V18H5.62V9.7Zm4.02 0h2.45v1.13h.04c.34-.65 1.18-1.33 2.44-1.33 2.61 0 3.09 1.72 3.09 3.96V18h-2.56v-4c0-.95-.02-2.18-1.33-2.18-1.33 0-1.53 1.04-1.53 2.1V18H9.64V9.7Z"></path>
                </svg>
              )}
              <span>{item.label}</span>
            </a>
          ))}

          <a href={hero.secondaryCta.href} class="action-link" download>
            <svg aria-hidden="true" viewBox="0 0 24 24" fill="none">
              <path d="M12 4v10" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"></path>
              <path d="m8.5 11.5 3.5 3.5 3.5-3.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"></path>
              <path d="M5 19h14" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"></path>
            </svg>
            <span>{hero.secondaryCta.label}</span>
          </a>
        </div>

        <p class="hero-work">
          <a href={hero.primaryCta.href} class="text-cta">{hero.primaryCta.label}</a>
          <span class="muted">·</span>
          <a href="/blog" class="text-cta page-swipe-link" data-swipe="left">Read my blog →</a>
        </p>
      </section>

      <SectionReveal client:visible id="about" className="section">
        <h2 class="section-title">{sections.aboutTitle}</h2>
        <div class="prose-markdown">
          {about.map((paragraph) => (
            <p set:html={mdInline(paragraph)}></p>
          ))}
        </div>
      </SectionReveal>

      <SectionReveal client:visible id="experience" className="section">
        <h2 class="section-title">{sections.experienceTitle}</h2>
        <div class="stacked-list">
          {experience.map((item) => (
            <article class="text-block">
              <p class="mono muted small">{item.date}</p>
              <h3>{item.title} <span class="muted">@ {item.org}</span></h3>
              <ul>
                {item.points.map((point) => (
                  <li set:html={mdInline(point)}></li>
                ))}
              </ul>
            </article>
          ))}
        </div>
      </SectionReveal>

      <SectionReveal client:visible id="education" className="section">
        <h2 class="section-title">{sections.educationTitle}</h2>
        <div class="stacked-list">
          {education.map((item) => (
            <article class="text-block">
              <p class="mono muted small">{item.date}</p>
              <h3>{item.degree}</h3>
              <p class="muted">{item.institution}</p>
              {item.grade && <p class="muted"><strong>Grade:</strong> {item.grade}</p>}
              <ul>
                {item.details.map((detail) => (
                  <li set:html={mdInline(detail)}></li>
                ))}
              </ul>
            </article>
          ))}
        </div>
      </SectionReveal>

      <SectionReveal client:visible id="certifications" className="section">
        <h2 class="section-title">{sections.certificationsTitle}</h2>
        <div class="cert-list">
          {certifications.map((cert) => (
            <article class="cert-item">
              <img src={cert.badge.src} alt={cert.badge.alt} loading="lazy" width="56" height="56" class="cert-badge" />
              <div>
                <p class="mono muted small">{cert.issuer}</p>
                <h3>{cert.name}</h3>
                <p class="muted">ID: {cert.id}</p>
                <p class="muted">{cert.date}</p>
              </div>
            </article>
          ))}
        </div>
      </SectionReveal>

      <SectionReveal client:visible id="projects" className="section">
        <h2 class="section-title">{sections.projectsTitle}</h2>
        <div class="projects-list">
          {projects.map((project, index) => (
            <article class="project-row" style={`--row-index:${index};`}>
              <p class="mono muted small">{project.year}</p>
              <div class="project-main">
                <h3>{project.name}</h3>
                <p class="muted">{project.stack}</p>
                <p>{project.desc}</p>
                {(() => {
                  const projectImages = Array.isArray(project.images) ? project.images : [];

                  if (projectImages.length === 1) {
                    const img = projectImages[0];
                    return (
                      <img
                        src={img.src}
                        alt={img.alt || `${project.name} preview`}
                        loading="lazy"
                        width="960"
                        height="540"
                        class="project-image"
                      />
                    );
                  }

                  if (projectImages.length > 1) {
                    return (
                      <div class="project-gallery">
                        {projectImages.map((img) => (
                          <img
                            src={img.src}
                            alt={img.alt || `${project.name} preview`}
                            loading="lazy"
                            width="960"
                            height="540"
                            class="project-image"
                          />
                        ))}
                      </div>
                    );
                  }

                  return null;
                })()}
                {project.highlights?.length > 0 && (
                  <ul class="project-bullets">
                    {project.highlights.map((bullet) => (
                      <li set:html={mdInline(bullet)}></li>
                    ))}
                  </ul>
                )}
                <p class="project-links">
                  <a href={project.demo} class="text-link">Live Demo</a>
                  <span class="muted">·</span>
                  <a href={project.github} class="text-link">GitHub</a>
                </p>
              </div>
            </article>
          ))}
        </div>
      </SectionReveal>

      <section class="section portfolio-back-top">
        <p class="hero-work">
          <a href="#top" class="text-cta">Back to top ↑</a>
        </p>
      </section>

    </main>

    <script>
      const links = Array.from(document.querySelectorAll<HTMLAnchorElement>('.rope-link'));
      const sections = links
        .map((link) => document.querySelector(link.getAttribute('href') || ''))
        .filter((section): section is HTMLElement => section instanceof HTMLElement);

      const setActive = (id: string) => {
        links.forEach((link) => {
          const isActive = link.getAttribute('href') === `#${id}`;
          link.classList.toggle('active', isActive);
          if (isActive) {
            link.setAttribute('aria-current', 'true');
          } else {
            link.removeAttribute('aria-current');
          }
        });
      };

      const resolveActiveSectionId = (): string | null => {
        if (!sections.length) return null;
        const marker = window.innerHeight * 0.33;
        let activeId = sections[0].id;

        for (const section of sections) {
          const rect = section.getBoundingClientRect();
          if (rect.top - marker <= 0) {
            activeId = section.id;
          } else {
            break;
          }
        }

        return activeId;
      };

      let activeTicking = false;
      const syncActiveSection = () => {
        const activeId = resolveActiveSectionId();
        if (activeId) setActive(activeId);
        activeTicking = false;
      };

      const queueActiveSectionSync = () => {
        if (activeTicking) return;
        activeTicking = true;
        requestAnimationFrame(syncActiveSection);
      };

      links.forEach((link) => {
        link.addEventListener('click', () => {
          const href = link.getAttribute('href') || '';
          const targetId = href.startsWith('#') ? href.slice(1) : '';
          if (targetId) setActive(targetId);
          queueActiveSectionSync();
        });
      });

      queueActiveSectionSync();
      window.addEventListener('scroll', queueActiveSectionSync, { passive: true });
      window.addEventListener('resize', queueActiveSectionSync);

      const progressBar = document.getElementById('scrollProgressBar');
      const updateProgress = () => {
        if (!progressBar) return;
        const max = document.documentElement.scrollHeight - window.innerHeight;
        const ratio = max > 0 ? window.scrollY / max : 0;
        progressBar.style.transform = `scaleX(${Math.min(Math.max(ratio, 0), 1)})`;
      };

      let targetX = window.innerWidth / 2;
      let targetY = window.innerHeight / 2;
      let currentX = targetX;
      let currentY = targetY;

      const updateGlow = (x: number, y: number) => {
        document.documentElement.style.setProperty('--cursor-x', `${x}px`);
        document.documentElement.style.setProperty('--cursor-y', `${y}px`);
      };

      const animateGlow = () => {
        currentX += (targetX - currentX) * 0.03;
        currentY += (targetY - currentY) * 0.03;
        updateGlow(currentX, currentY);
        requestAnimationFrame(animateGlow);
      };

      window.addEventListener('mousemove', (event) => {
        targetX = event.clientX;
        targetY = event.clientY;
      });

      window.addEventListener('mouseleave', () => {
        targetX = window.innerWidth / 2;
        targetY = window.innerHeight / 2;
      });

      animateGlow();

      const lightbox = document.getElementById('imageLightbox');
      const lightboxImage = document.getElementById('lightboxImage');
      const lightboxClose = document.getElementById('lightboxClose');
      const lightboxPrev = document.getElementById('lightboxPrev');
      const lightboxNext = document.getElementById('lightboxNext');
      const projectImages = Array.from(document.querySelectorAll<HTMLImageElement>('.project-image'));

      let activeLightboxImages: HTMLImageElement[] = [];
      let activeLightboxIndex = 0;

      const updateLightboxNavVisibility = () => {
        const hasMultiple = activeLightboxImages.length > 1;
        if (lightboxPrev instanceof HTMLButtonElement) {
          lightboxPrev.hidden = !hasMultiple;
        }
        if (lightboxNext instanceof HTMLButtonElement) {
          lightboxNext.hidden = !hasMultiple;
        }
      };

      const renderLightboxImage = () => {
        if (!(lightboxImage instanceof HTMLImageElement)) return;
        if (!activeLightboxImages.length) return;
        const currentImage = activeLightboxImages[activeLightboxIndex];
        lightboxImage.setAttribute('src', currentImage.currentSrc || currentImage.src);
        lightboxImage.setAttribute('alt', currentImage.alt || 'Project image preview');
      };

      const closeLightbox = () => {
        if (!(lightbox instanceof HTMLElement) || !(lightboxImage instanceof HTMLImageElement)) return;
        lightbox.classList.remove('open');
        lightbox.setAttribute('aria-hidden', 'true');
        lightboxImage.setAttribute('src', '');
        lightboxImage.setAttribute('alt', '');
        activeLightboxImages = [];
        activeLightboxIndex = 0;
        updateLightboxNavVisibility();
      };

      const openLightbox = (images: HTMLImageElement[], startIndex: number) => {
        if (!(lightbox instanceof HTMLElement) || !(lightboxImage instanceof HTMLImageElement)) return;
        activeLightboxImages = images;
        activeLightboxIndex = Math.min(Math.max(startIndex, 0), Math.max(images.length - 1, 0));
        updateLightboxNavVisibility();
        renderLightboxImage();
        lightbox.classList.add('open');
        lightbox.setAttribute('aria-hidden', 'false');
      };

      const navigateLightbox = (direction: number) => {
        if (!activeLightboxImages.length) return;
        activeLightboxIndex = (activeLightboxIndex + direction + activeLightboxImages.length) % activeLightboxImages.length;
        renderLightboxImage();
      };

      projectImages.forEach((image) => {
        image.addEventListener('click', () => {
          const gallery = image.closest('.project-gallery');
          const imagesInGroup = gallery
            ? Array.from(gallery.querySelectorAll<HTMLImageElement>('.project-image'))
            : [image];
          const startIndex = Math.max(imagesInGroup.indexOf(image), 0);
          openLightbox(imagesInGroup, startIndex);
        });
      });

      lightboxPrev?.addEventListener('click', (event) => {
        event.stopPropagation();
        navigateLightbox(-1);
      });

      lightboxNext?.addEventListener('click', (event) => {
        event.stopPropagation();
        navigateLightbox(1);
      });

      lightboxClose?.addEventListener('click', closeLightbox);
      lightbox?.addEventListener('click', (event) => {
        if (event.target === lightbox) closeLightbox();
      });

      window.addEventListener('keydown', (event) => {
        const isOpen = lightbox instanceof HTMLElement && lightbox.classList.contains('open');
        if (!isOpen) return;
        if (event.key === 'Escape') closeLightbox();
        if (event.key === 'ArrowLeft') navigateLightbox(-1);
        if (event.key === 'ArrowRight') navigateLightbox(1);
      });

      updateProgress();
      window.addEventListener('scroll', updateProgress, { passive: true });

      const heroMeta = document.querySelector('.hero-meta');
      const heroLocalTime = document.getElementById('heroLocalTime');
      if (heroMeta && heroLocalTime) {
        const timeZone = heroMeta.getAttribute('data-timezone') || 'Europe/Lisbon';
        const formatter = new Intl.DateTimeFormat('en-GB', {
          hour: '2-digit',
          minute: '2-digit',
          hour12: false,
          timeZone
        });

        const updateLocalTime = () => {
          heroLocalTime.textContent = formatter.format(new Date());
        };

        updateLocalTime();
        setInterval(updateLocalTime, 15000);
      }

      const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      const swipeLinks = Array.from(document.querySelectorAll<HTMLAnchorElement>('a.page-swipe-link[data-swipe="left"]'));

      swipeLinks.forEach((link) => {
        link.addEventListener('click', (event) => {
          if (prefersReducedMotion) return;
          if (event.metaKey || event.ctrlKey || event.shiftKey || event.altKey) return;
          const href = link.getAttribute('href');
          if (!href || href.startsWith('#')) return;
          const targetUrl = new URL(href, window.location.href);
          if (targetUrl.origin !== window.location.origin) return;
          event.preventDefault();
          document.body.classList.add('page-swipe-left');
          window.setTimeout(() => {
            window.location.href = targetUrl.href;
          }, 360);
        });
      });
    </script>
  </body>
</html>
